# Application
APP_NAME="AI Lead Generation System"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://lead_user:lead_pass@localhost:5432/lead_db

# Security
ADMIN_API_KEY=change-me-before-production

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# OpenAI (Phase 2 — not required for Phase 1)
OPENAI_API_KEY=sk-placeholder-not-required-in-phase-1
OPENAI_MODEL=gpt-4o-mini

# n8n Handoff Webhook (Phase 2 — not required for Phase 1)
N8N_HANDOFF_WEBHOOK_URL=https://your-n8n-instance/webhook/handoff
